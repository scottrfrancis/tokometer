# ~/.tokometer/flightplan.env -- sourced by tokometer-push.service.
# Per flightplan/docs/SRS.md §8.3.

# Beaufort REST ingest endpoint (Tailscale; bearer auth)
FLIGHTPLAN_INGEST_URL=https://hasami.tailnet:7321

# Per-device write-only token (issued by `beaufort device add <host>` in Block 1.3)
FLIGHTPLAN_INGEST_TOKEN=

# Optional overrides:
# FLIGHTPLAN_PUSH_BATCH=1000              # rows per POST
# TOKOMETER_HOME=/home/scott/.tokometer    # where ledger.db + state live
# TOKOMETER_REPO_ROOT=/home/scott/repos    # where to scan for .claude/session-logs
