# tokometer per-machine config -- copy to ~/.tokometer/tokometer.env (install.sh writes one
# automatically with detected values). Sourced by daily.sh and harvest.sh; local only.

# Which harnesses to harvest + surface, space-separated. Remove the ones you don't
# use on this machine to avoid irrelevant errors/advisories (e.g. Cursor needs a
# browser login). Available: opencode droid copilot claude_code git_metrics gh_metrics cursor
# Unset/blank = all enabled.
export TOKOMETER_HARNESSES="opencode claude_code git_metrics gh_metrics"

# Where your git repos live. Scanned RECURSIVELY (TOKOMETER_GIT_DEPTH levels deep),
# so nested layouts like <root>/<group>/<repo> are picked up.
export TOKOMETER_GIT_ROOT="$HOME/workspace"

# Author email(s) to count toward code metrics -- your own commit identities,
# comma-separated (matched as OR). Set to '*' to count every author in the repo.
export TOKOMETER_GIT_AUTHOR="you@example.com"

# How deep to recurse from TOKOMETER_GIT_ROOT when discovering repos.
export TOKOMETER_GIT_DEPTH="4"

# Claude Code multi-account discovery. The collector scans ~/.claude plus every
# profile config root matched by this glob; each is attributed to its own
# account/subscription via that profile's history.jsonl. Override only if your
# profiles live elsewhere, or set CLAUDE_CONFIG_ROOTS to an explicit list.
# export CLAUDE_PROFILES_GLOB="$HOME/.claude-profiles/*/.claude"
# export CLAUDE_CONFIG_ROOTS="$HOME/.claude:$HOME/.claude-profiles/al/.claude"

# OPTIONAL Claude limit gauges. Anthropic doesn't publish fixed token thresholds for
# its rolling windows, so the report just shows your usage per window by default. If
# you've observed your own caps (in total tokens), set them here to render a % bar:
# export TOKOMETER_CLAUDE_LIMIT_5H="..."      # 5-hour session window
# export TOKOMETER_CLAUDE_LIMIT_24H="..."     # daily window
# export TOKOMETER_CLAUDE_LIMIT_7D="..."      # weekly window
# export TOKOMETER_CLAUDE_LIMIT_OPUS7D="..."  # weekly Opus-only window (Max plans)
