#!/usr/bin/env bash
# observe -- 5-second manual observation entry (quality rating / stall / continue).
# Works from Git Bash on Windows and any POSIX shell. See collectors/copilot_observe.py.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PY="$(command -v python3 || command -v python)"
exec "$PY" "$SCRIPT_DIR/collectors/copilot_observe.py" "$@"
